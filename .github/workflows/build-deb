name: Build Spartan tvOS DEB

on:
  workflow_dispatch:
  push:
    branches:
      - main

permissions:
  contents: write

jobs:
  build:
    runs-on: macos-15

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Select Xcode
        run: sudo xcode-select -s /Applications/Xcode.app

      - name: Show Xcode Version
        run: xcodebuild -version

      - name: Resolve Packages
        run: |
          xcodebuild -resolvePackageDependencies \
          -project Spartan.xcodeproj

      - name: Build Spartan tvOS
        run: |
          xcodebuild \
          -project Spartan.xcodeproj \
          -scheme Spartan \
          -configuration Release \
          -sdk appletvos \
          -destination 'generic/platform=tvOS' \
          ARCHS=arm64 \
          ONLY_ACTIVE_ARCH=NO \
          CODE_SIGNING_ALLOWED=NO \
          CODE_SIGNING_REQUIRED=NO \
          CODE_SIGN_IDENTITY="" \
          clean build

      - name: Locate App
        run: |
          APP_PATH=$(find ~/Library/Developer/Xcode/DerivedData -name "Spartan.app" | head -n 1)

          echo "APP_PATH=$APP_PATH" >> $GITHUB_ENV

          if [ ! -d "$APP_PATH" ]; then
            echo "Spartan.app not found!"
            exit 1
          fi

      - name: Create DEB Structure
        run: |
          mkdir -p package/Applications
          mkdir -p package/DEBIAN

          cp -R "$APP_PATH" package/Applications/

          cat > package/DEBIAN/control <<EOF
          Package: com.fauxly.spartan
          Name: Spartan
          Version: 1.0.${{ github.run_number }}
          Architecture: iphoneos-arm
          Description: Spartan File Manager for tvOS
          Maintainer: Fauxly
          Author: Fauxly
          Section: Applications
          Depends: firmware (>= 15.0)
          EOF

      - name: Build DEB Package
        run: |
          brew install dpkg

          dpkg-deb \
          --build package \
          Spartan-tvOS.deb

      - name: Create TAR Archive
        run: |
          tar -czf Spartan-tvOS.tar.gz package

      - name: Upload Build Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: Spartan-tvOS
          path: |
            Spartan-tvOS.deb
            Spartan-tvOS.tar.gz

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: tvos-build-${{ github.run_number }}
          name: Spartan tvOS Build ${{ github.run_number }}
          files: |
            Spartan-tvOS.deb
            Spartan-tvOS.tar.gz
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}